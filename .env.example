DATABASE_URL="mongodb://localhost:27017/staycare"
PORT=5000

# Frontend origin for CORS
CLIENT_URL="http://localhost:5173"

# Runtime environment
NODE_ENV="development"

# JWT configuration
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Token lifetimes in seconds
# Default: 15 minutes (900s) for access, 7 days (604800s) for refresh
ACCESS_TOKEN_EXPIRES=900
REFRESH_TOKEN_EXPIRES=604800

# SMTP config for invitation emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="StayCare <your-email@gmail.com>"